# Copy this file to ".env" (same folder) and edit it.
# ".env" is the ONLY file you ever need to touch to switch providers or add a key.

# Which LLM backend to use: mock | anthropic | gemini | groq
PROVIDER=mock

# --- Paste ONE key below, matching whichever PROVIDER you picked above ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional overrides (sensible defaults already set in llm_client.py)
# MODEL=claude-haiku-4-5-20251001
MAX_TOKENS=250

# Comma-separated browser origins permitted to call the API. Use your Railway
# public URL in production, e.g. https://stadiummind-production.up.railway.app
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Used by ops_dashboard.py to find the backend
BACKEND_URL=http://localhost:8000
